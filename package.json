{
  "name": "wakatime-bot",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.16.0",
  "scripts": {
    "dev:bot": "NODE_NO_WARNINGS=1 node --env-file=.env --experimental-transform-types --watch ./src/main.ts bot",
    "dev:api": "NODE_NO_WARNINGS=1 node --env-file=.env --experimental-transform-types --watch ./src/main.ts api",
    "lint": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@fullstacksjs/toolbox": "4.22.0",
    "awilix": "13.0.5",
    "dedent": "1.7.2",
    "deepmerge-ts": "7.1.5",
    "grammy": "1.45.1",
    "h3": "2.0.1-rc.25",
    "lowdb": "7.0.1",
    "puppeteer": "24.42.0",
    "valibot": "1.4.2"
  },
  "devDependencies": {
    "@fullstacksjs/eslint-config": "14.8.0",
    "@fullstacksjs/tsconfig": "2.0.0",
    "@types/node": "24.3.0",
    "eslint": "10.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.2.0",
    "prettier": "3.9.6",
    "typescript": "^6"
  },
  "volta": {
    "node": "22.19.0"
  }
