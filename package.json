{
  "name": "wakatime-bot",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.16.0",
  "scripts": {
    "dev:bot": "NODE_NO_WARNINGS=1 node --env-file=.env --experimental-transform-types --watch ./src/main.ts bot",
    "dev:api": "NODE_NO_WARNINGS=1 node --env-file=.env --experimental-transform-types --watch ./src/main.ts api",
    "lint": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@fullstacksjs/toolbox": "4.22.0",
    "awilix": "13.0.5",
    "dedent": "1.7.2",
    "deepmerge-ts": "7.1.5",
    "grammy": "1.42.0",
    "h3": "1.15.4",
    "lowdb": "7.0.1",
    "puppeteer": "24.42.0",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@fullstacksjs/eslint-config": "14.2.0",
    "@fullstacksjs/tsconfig": "2.0.0",
    "@types/node": "24.3.0",
    "eslint": "9.34.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "typescript": "5.9.3"
  },
  "volta": {
    "node": "22.19.0"
  }
