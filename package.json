{
  "name": "wakatime-bot",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev:bot": "NODE_NO_WARNINGS=1 node --env-file=.env --experimental-transform-types --watch ./src/main.ts bot",
    "dev:api": "NODE_NO_WARNINGS=1 node --env-file=.env --experimental-transform-types --watch ./src/main.ts api",
    "lint": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@fullstacksjs/toolbox": "4.20.0",
    "awilix": "12.0.5",
    "axios": "1.11.0",
    "dedent": "1.6.0",
    "deepmerge-ts": "7.1.5",
    "grammy": "1.38.1",
    "h3": "1.15.4",
    "lowdb": "7.0.1",
    "puppeteer": "24.17.0",
    "valibot": "1.1.0"
  },
  "devDependencies": {
    "@fullstacksjs/eslint-config": "13.2.2",
    "@fullstacksjs/tsconfig": "2.0.0",
    "@types/node": "24.3.0",
    "eslint": "9.34.0",
    "husky": "9.1.7",
    "lint-staged": "16.1.5",
    "prettier": "3.6.2",
    "typescript": "5.8.2"
  },
  "volta": {
    "node": "22.14.0",
    "pnpm": "10.15.0"
  }
